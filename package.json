    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.0",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.12",
