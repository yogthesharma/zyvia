    "@adonisjs/vite": "^5.1.0",
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@inertiajs/react": "^2.3.18",
    "@radix-ui/react-slot": "^1.2.4",
    "@tuyau/core": "^1.2.2",
